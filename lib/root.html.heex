<!DOCTYPE html>
<html lang="{@lang}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{@title}</title>
  <style>
    body { margin: 0; padding: 0; max-width: none; background: #ffffff; }
  </style>
</head>
<body>
  <div id="dialup-root">
    {raw(@inner_content)}
  </div>
  <script src="/idiomorph.js"></script>
  <script src="/dialup.js"></script>
  <script src="/ec-demo.js"></script>
  <script src="/mcp-demo.js"></script>
  <script>
    window.DialupApp = Dialup;
    Dialup.connect();
  </script>
</body>
</html>
